  }

  function message_show(tabflag) {
	  if ( tabflag == '2' ) {
		  document.getElementById('tab2').click();
		  document.getElementById("anew").focus();
	  }else if ( tabflag == '3' ) {
		  document.getElementById('tab3').click();
		  document.getElementById("anew1").focus();
	  }else if ( tabflag == '4' ) {
		  document.getElementById('tab4').click();
		  document.getElementById("diste1").focus();
	  }
  }
  
</script>

